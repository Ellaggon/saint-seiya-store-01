generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AuditLog {
  id          String   @id @default(uuid())
  entity      String
  entityId    String
  action      String
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  role                 UserRole              @default(CUSTOMER)
  status               UserStatus            @default(ACTIVE)
  createdAt            DateTime              @default(now())
  address              String?
  name                 String?
  deletedAt            DateTime?
  updatedAt            DateTime              @updatedAt
  orders               Order[]
  preorderReservations PreorderReservation[]
  reservations         Reservation[]

  @@index([email])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  imageUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Character {
  id        String             @id @default(uuid())
  name      String             @unique
  createdAt DateTime           @default(now())
  slug      String             @unique
  products  ProductCharacter[]
}

model Product {
  id                String             @id @default(uuid())
  name              String
  description       String
  price             Decimal            @db.Decimal(12, 2)
  categoryId        String
  collectionId      String
  height            Decimal            @db.Decimal(6, 2)
  material          String?
  stock             Int                @default(0)
  imageUrl          String
  status            ProductStatus      @default(DRAFT)
  createdAt         DateTime           @default(now())
  deletedAt         DateTime?
  slug              String             @unique
  updatedAt         DateTime           @updatedAt
  inventories       Inventory[]
  orderItems        OrderItem[]
  preorderCampaigns PreorderCampaign[]
  category          Category           @relation(fields: [categoryId], references: [id])
  collection        Collection         @relation(fields: [collectionId], references: [id])
  characters        ProductCharacter[]
  reservations      Reservation[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([collectionId])
  @@index([deletedAt])
}

model ProductCharacter {
  productId   String
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@id([productId, characterId])
  @@index([characterId])
}

model Inventory {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  location  String
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([location])
}

model Reservation {
  id        String            @id @default(uuid())
  userId    String
  productId String
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  expiresAt DateTime?
  product   Product           @relation(fields: [productId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([productId])
}

model PreorderCampaign {
  id               String                   @id @default(uuid())
  productId        String
  product          Product                  @relation(fields: [productId], references: [id])
  status           PreorderCampaignStatus   @default(DRAFT)
  totalSlots       Int
  depositType      PreorderDepositType      @default(PERCENT)
  depositValue     Decimal                  @db.Decimal(12, 2)
  allowFullPayment Boolean                  @default(true)
  opensAt          DateTime?
  closesAt         DateTime?
  releaseDate      DateTime?
  etaStart         DateTime?
  etaEnd           DateTime?
  etaLabel         String?
  terms            String?
  arrivalNotes     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  reservations     PreorderReservation[]

  @@index([productId])
  @@index([status])
  @@index([opensAt])
  @@index([etaStart])
  @@index([deletedAt])
}

model PreorderReservation {
  id              String                    @id @default(uuid())
  campaignId      String
  campaign        PreorderCampaign          @relation(fields: [campaignId], references: [id])
  userId          String
  user            User                      @relation(fields: [userId], references: [id])
  quantity        Int                       @default(1)
  unitPrice       Decimal                   @db.Decimal(12, 2)
  totalAmount     Decimal                   @db.Decimal(14, 2)
  depositRequired Decimal                   @db.Decimal(12, 2)
  status          PreorderReservationStatus @default(PENDING)
  expiresAt       DateTime?
  confirmedAt     DateTime?
  canceledAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  payments        PreorderPayment[]

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([campaignId, userId])
}

model PreorderPayment {
  id                String                   @id @default(uuid())
  reservationId     String
  reservation       PreorderReservation      @relation(fields: [reservationId], references: [id])
  kind              PreorderPaymentKind
  amount            Decimal                  @db.Decimal(12, 2)
  status            PreorderPaymentStatus    @default(PENDING)
  provider          PreorderPaymentProvider?
  providerPaymentId String?
  metadata          Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  paidAt            DateTime?

  @@index([reservationId])
  @@index([status])
  @@index([provider, providerPaymentId])
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  status            OrderStatus @default(PENDING)
  totalAmount       Decimal     @db.Decimal(14, 2)
  shippingTrackerId String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  PRE_ORDER
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
  EXPIRED
}

enum PreorderCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD_OUT
  ARRIVED
  CLOSED
  CANCELED
}

enum PreorderDepositType {
  PERCENT
  FIXED
  FULL
}

enum PreorderReservationStatus {
  PENDING
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELED
  EXPIRED
  FULFILLED
}

enum PreorderPaymentKind {
  DEPOSIT
  FULL
  BALANCE
}

enum PreorderPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum PreorderPaymentProvider {
  MANUAL
  STRIPE
  MERCADOPAGO
  WEBPAY
  PAYPAL
}
