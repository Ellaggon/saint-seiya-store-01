---
import MainLayout from "@/ui/layouts/MainLayout.astro";
import AdminReservationTable from "@/ui/components/admin/preorders/AdminReservationTable.astro";
import {
  getAdminPreorder,
  listAdminPreorderReservations,
} from "@/ui/pages/admin/preorders/adminPreorderApi";

const user = Astro.locals.user;
if (!user || user.role !== "ADMIN") {
  return Astro.redirect("/login");
}

const id = Astro.params.id;
if (!id) {
  return Astro.redirect("/admin/preorders");
}

const error = Astro.url.searchParams.get("error");
const cookie = Astro.request.headers.get("cookie");
const [preorder, reservations] = await Promise.all([
  getAdminPreorder(Astro.url.origin, cookie, id),
  listAdminPreorderReservations(Astro.url.origin, cookie, id),
]);
---

<MainLayout title={`Reservas - ${preorder.product.name}`}>
  <div class="max-w-[1280px] mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
      <div class="space-y-2">
        <a href="/admin/preorders" class="inline-flex items-center text-zinc-500 hover:text-white transition-colors text-[10px] font-black uppercase tracking-widest mb-4">
          Volver a preventas
        </a>
        <p class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em]">Reservas preventa</p>
        <h1 class="text-4xl font-black text-white uppercase tracking-tighter">{preorder.product.name}</h1>
        <div class="w-12 h-1 bg-amber-500"></div>
      </div>
      <div class="border border-zinc-900 bg-zinc-950 px-5 py-4">
        <p class="text-zinc-500 text-[10px] font-black uppercase tracking-widest">Reservado</p>
        <p class="text-white text-xl font-black">{preorder.campaign.reservedUnits}/{preorder.campaign.totalSlots}</p>
      </div>
    </div>

    {error && (
      <div class="border border-red-500/30 bg-red-500/5 text-red-400 px-5 py-4 text-xs font-bold uppercase tracking-widest mb-8">
        {error}
      </div>
    )}

    <AdminReservationTable preorderId={id} reservations={reservations} />
  </div>
</MainLayout>
