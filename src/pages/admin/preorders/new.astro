---
import MainLayout from "@/ui/layouts/MainLayout.astro";
import AdminPreorderForm from "@/ui/components/admin/preorders/AdminPreorderForm.astro";
import { listProductsForPreorderAdmin } from "@/ui/pages/admin/preorders/adminPreorderApi";

const user = Astro.locals.user;
if (!user || user.role !== "ADMIN") {
  return Astro.redirect("/login");
}

const error = Astro.url.searchParams.get("error");
const products = await listProductsForPreorderAdmin(Astro.url.origin);
---

<MainLayout title="Admin - Nueva Preventa">
  <div class="max-w-[900px] mx-auto px-6 py-12">
    <a href="/admin/preorders" class="inline-flex items-center text-zinc-500 hover:text-white transition-colors text-[10px] font-black uppercase tracking-widest mb-8">
      Volver a preventas
    </a>
    <div class="space-y-2 mb-12">
      <p class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em]">Nueva campaña</p>
      <h1 class="text-4xl font-black text-white uppercase tracking-tighter">Crear Preventa</h1>
      <div class="w-12 h-1 bg-amber-500"></div>
    </div>

    <AdminPreorderForm products={products} error={error} />
  </div>
</MainLayout>
