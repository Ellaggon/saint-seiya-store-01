---
import ProductForm from "@/ui/pages/admin/ProductForm.astro";

// Protect route
const user = Astro.locals.user;
if (!user || user.role !== "ADMIN") {
  return Astro.redirect("/login");
}

const { id } = Astro.params;

// Fetch data from endpoints
const productResponse = await fetch(
  new URL(`/api/products/${id}`, Astro.url.origin),
);
const product = await productResponse.json();

if (!product || product.deletedAt) {
  return Astro.redirect("/admin/products");
}

const categoriesResponse = await fetch(
  new URL("/api/categories", Astro.url.origin),
);
const categories = await categoriesResponse.json();

const collectionsResponse = await fetch(
  new URL("/api/collections", Astro.url.origin),
);
const collections = await collectionsResponse.json();
---

<ProductForm
  product={product}
  categories={categories}
  collections={collections}
  isEditing={true}
/>
