---
import MainLayout from "@/ui/layouts/MainLayout.astro";
import { prisma } from "@/infrastructure/database/prisma";

// Protect route
const user = Astro.locals.user;
if (!user || user.role !== "ADMIN") {
  return Astro.redirect("/login");
}

const { id } = Astro.params;

// Fetch the product to edit
const product = await prisma.product.findUnique({
  where: { id },
  include: { category: true },
});

if (!product || product.deletedAt) {
  return Astro.redirect("/admin/products");
}

// Fetch categories for the select dropdown
const categories = await prisma.category.findMany({
  orderBy: { name: "asc" },
});

// Enums from Prisma
const statusOptions = [
  "DRAFT",
  "PUBLISHED",
  "PRE_ORDER",
  "OUT_OF_STOCK",
  "ARCHIVED",
];
---

<MainLayout title={`Editar - ${product.name}`}>
  <div class="max-w-[800px] mx-auto px-6 py-12">
    <!-- Back Button -->
    <a
      href="/admin/products"
      class="inline-flex items-center text-zinc-500 hover:text-white transition-colors text-[10px] font-black uppercase tracking-widest mb-8"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="square"
        stroke-linejoin="round"
        class="mr-2"
        ><path d="m15 18-6-6 6-6"></path>
      </svg>
      Volver al Listado
    </a>

    <!-- Header -->
    <div class="space-y-2 mb-12">
      <p
        class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em]"
      >
        Edición de Archivo
      </p>
      <h1 class="text-4xl font-black text-white uppercase tracking-tighter">
        {product.name}
      </h1>
      <div class="w-12 h-1 bg-amber-500"></div>
    </div>

    <!-- Form Section -->
    <form
      action="/admin/products/actions"
      method="POST"
      class="space-y-8 bg-zinc-950 p-8 border border-zinc-900 shadow-2xl"
    >
      <input type="hidden" name="_action" value="update" />
      <input type="hidden" name="id" value={product.id} />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Name -->
        <div class="space-y-2">
          <label
            for="name"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Nombre de la Figura</label
          >
          <input
            type="text"
            id="name"
            name="name"
            value={product.name}
            required
            placeholder="Ej: Seiya de Pegaso V3"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Slug -->
        <div class="space-y-2">
          <label
            for="slug"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >URL Personalizada</label
          >
          <input
            type="text"
            id="slug"
            name="slug"
            value={product.slug}
            placeholder="seiya-pegaso-v3-ex"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Price -->
        <div class="space-y-2">
          <label
            for="price"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Precio (EUR)</label
          >
          <input
            type="number"
            id="price"
            name="price"
            value={product.price.toString()}
            step="0.01"
            required
            placeholder="99.99"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Height -->
        <div class="space-y-2">
          <label
            for="height"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Altura (cm)</label
          >
          <input
            type="number"
            id="height"
            name="height"
            value={product.height.toString()}
            step="0.1"
            required
            placeholder="18.0"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Category -->
        <div class="space-y-2">
          <label
            for="categoryId"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Línea / Colección</label
          >
          <select
            id="categoryId"
            name="categoryId"
            required
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors appearance-none cursor-pointer"
          >
            {
              categories.map((cat) => (
                <option value={cat.id} selected={cat.id === product.categoryId}>
                  {cat.name}
                </option>
              ))
            }
          </select>
        </div>

        <!-- Status -->
        <div class="space-y-2">
          <label
            for="status"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Estado del Archivo</label
          >
          <select
            id="status"
            name="status"
            required
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors appearance-none cursor-pointer"
          >
            {
              statusOptions.map((opt) => (
                <option value={opt} selected={opt === product.status}>
                  {opt}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <!-- Image URL -->
      <div class="space-y-2">
        <label
          for="imageUrl"
          class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
          >Ruta de Imagen (URL)</label
        >
        <input
          type="url"
          id="imageUrl"
          name="imageUrl"
          value={product.imageUrl}
          required
          placeholder="https://servidor.com/imagenes/seiya.jpg"
          class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
        />
      </div>

      <!-- Description -->
      <div class="space-y-2">
        <label
          for="description"
          class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
          >Crónicas de la Armadura (Descripción)</label
        >
        <textarea
          id="description"
          name="description"
          rows="5"
          required
          placeholder="Describe la figura, materiales, accesorios..."
          class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors resize-none"
          >{product.description}</textarea
        >
      </div>

      <!-- Submit Button -->
      <div class="pt-6">
        <button
          type="submit"
          class="w-full bg-white text-black text-[11px] font-black uppercase tracking-[0.2em] py-5 hover:bg-amber-500 transition-all duration-300"
        >
          Guardar Cambios en el Archivo
        </button>
      </div>
    </form>
  </div>
</MainLayout>
