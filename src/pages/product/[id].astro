---
import DetailPage from "../../ui/pages/product/detail.astro";
import { getProductById } from "@/endpoints/api/products/getProductById";
import { createGetPreorderDetailUseCase } from "@/infrastructure/preorders/PreorderUseCaseFactory";
import { ApplicationError } from "@/application/errors/ApplicationError";

const id = Astro.params.id;
let product = null;
let preorder = null;

if (id) {
  product = await getProductById(id);

  if (product) {
    try {
      preorder = await createGetPreorderDetailUseCase().execute({
        productId: product.id,
      });
    } catch (error) {
      const appError = ApplicationError.normalizeUnknownError(error);
      if (appError.code !== "INVALID_PREORDER_STATE") {
        throw appError;
      }
    }
  }
}
---

<DetailPage product={product} preorder={preorder} />
