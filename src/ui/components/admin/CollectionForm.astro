---
import MainLayout from "@/ui/layouts/MainLayout.astro";

interface Props {
  collection?: any;
  isEditing?: boolean;
}

const { collection, isEditing = false } = Astro.props;
---

<MainLayout
  title={isEditing
    ? `Editar Colección - ${collection.name}`
    : "Admin - Nueva Colección"}
>
  <div class="max-w-[800px] mx-auto px-6 py-12">
    <!-- Back Button -->
    <a
      href="/admin/collections"
      class="inline-flex items-center text-zinc-500 hover:text-white transition-colors text-[10px] font-black uppercase tracking-widest mb-8"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="square"
        stroke-linejoin="round"
        class="mr-2"
        ><path d="m15 18-6-6 6-6"></path>
      </svg>
      Volver al Listado
    </a>

    <!-- Header -->
    <div class="space-y-2 mb-12">
      <p
        class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em]"
      >
        {isEditing ? "Gestión de Colección" : "Nueva Colección"}
      </p>
      <h1 class="text-4xl font-black text-white uppercase tracking-tighter">
        {isEditing ? collection.name : "Crear Colección"}
      </h1>
      <div class="w-12 h-1 bg-amber-500"></div>
    </div>

    <!-- Form Section -->
    <form
      action="/api/admin/collections/actions"
      method="POST"
      class="space-y-8 bg-zinc-950 p-8 border border-zinc-900 shadow-2xl"
    >
      <input
        type="hidden"
        name="_action"
        value={isEditing ? "update" : "create"}
      />
      {Astro.url.searchParams.has("popup") && (
        <input type="hidden" name="isPopup" value="true" />
      )}
      {isEditing && <input type="hidden" name="id" value={collection.id} />}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Name -->
        <div class="space-y-2">
          <label
            for="name"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Nombre de la Colección</label
          >
          <input
            type="text"
            id="name"
            name="name"
            value={collection?.name || ""}
            required
            placeholder="Ej: Myth Cloth EX"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Slug -->
        <div class="space-y-2">
          <label
            for="slug"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Slug (URL)</label
          >
          <input
            type="text"
            id="slug"
            name="slug"
            value={collection?.slug || ""}
            required
            placeholder="myth-cloth-ex"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>
      </div>

      <!-- Description -->
      <div class="space-y-2">
        <label
          for="description"
          class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
          >Descripción</label
        >
        <textarea
          id="description"
          name="description"
          rows="4"
          placeholder="Detalles sobre esta línea de productos..."
          class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors resize-none"
          >{collection?.description || ""}</textarea
        >
      </div>

      <!-- IsActive (Soft Delete Toggle) -->
      <div class="flex items-center gap-4">
        <label class="relative inline-flex items-center cursor-pointer">
          <input
            type="checkbox"
            name="isActive"
            value="true"
            checked={collection ? !collection.deletedAt : true}
            class="sr-only peer"
          />
          <div
            class="w-11 h-6 bg-zinc-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-zinc-400 after:border-zinc-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500 peer-checked:after:bg-white"
          >
          </div>
          <span
            class="ml-3 text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Estado Activo</span
          >
        </label>
      </div>

      <!-- Submit Button -->
      <div class="pt-6">
        <button
          type="submit"
          class="w-full bg-white text-black text-[11px] font-black uppercase tracking-[0.2em] py-5 hover:bg-amber-500 transition-all duration-300"
        >
          {isEditing ? "Actualizar Colección" : "Crear Colección"}
        </button>
      </div>
    </form>
  </div>
</MainLayout>
