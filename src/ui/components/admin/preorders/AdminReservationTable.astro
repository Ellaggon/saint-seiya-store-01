---
import type { PreorderReservationDTO } from "@/application/dto/preorder.dto";
import { formatPrice } from "@/lib/utils";

interface Props {
  preorderId: string;
  reservations: PreorderReservationDTO[];
}

const { preorderId, reservations } = Astro.props;
---

<div class="bg-zinc-950 border border-zinc-900 overflow-x-auto">
  <table class="w-full min-w-[960px] text-left border-collapse">
    <thead class="bg-black border-b border-zinc-900">
      <tr>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Cliente</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Cantidad</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Depósito pagado</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Saldo</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Estado</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest">Fecha</th>
        <th class="px-6 py-4 text-[10px] font-black text-amber-500 uppercase tracking-widest text-right">Acciones</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-900">
      {
        reservations.length === 0 ? (
          <tr>
            <td colspan="7" class="px-6 py-12 text-center text-zinc-500 text-xs uppercase tracking-widest italic">
              Esta preventa todavía no tiene reservas.
            </td>
          </tr>
        ) : (
          reservations.map((reservation) => (
            <tr class="hover:bg-zinc-900/50 transition-colors">
              <td class="px-6 py-5">
                <p class="text-white font-bold text-xs uppercase tracking-tight">{reservation.userId}</p>
                <a href={`/admin/users/${reservation.userId}`} class="text-zinc-600 hover:text-amber-500 text-[10px] uppercase tracking-widest">
                  Ver usuario
                </a>
              </td>
              <td class="px-6 py-5 text-white font-black text-sm">{reservation.quantity}</td>
              <td class="px-6 py-5 text-amber-500 font-black text-sm">{formatPrice(reservation.paidAmount)}</td>
              <td class="px-6 py-5 text-white font-black text-sm">{formatPrice(reservation.balanceDue)}</td>
              <td class="px-6 py-5">
                <span class="text-[9px] font-black uppercase px-2 py-1 tracking-widest border border-zinc-800 bg-zinc-900 text-zinc-400">
                  {reservation.status}
                </span>
              </td>
              <td class="px-6 py-5 text-zinc-600 text-[10px] font-bold">
                {new Date(reservation.createdAt).toLocaleDateString("es-ES")}
              </td>
              <td class="px-6 py-5 text-right">
                <div class="flex justify-end items-center gap-3">
                  <form action="/admin/preorders/actions" method="POST" class="flex items-center gap-2">
                    <input type="hidden" name="_action" value="manualPayment" />
                    <input type="hidden" name="id" value={preorderId} />
                    <input type="hidden" name="reservationId" value={reservation.id} />
                    <select name="kind" class="bg-black border border-zinc-800 px-2 py-2 text-zinc-300 text-[10px] font-bold uppercase">
                      <option value="DEPOSIT">Deposit</option>
                      <option value="BALANCE">Balance</option>
                      <option value="FULL">Full</option>
                    </select>
                    <input
                      type="number"
                      name="amount"
                      min="0.01"
                      step="0.01"
                      placeholder={String(reservation.balanceDue)}
                      class="w-24 bg-black border border-zinc-800 px-2 py-2 text-white text-[10px]"
                    />
                    <button type="submit" class="text-[10px] font-black text-amber-500 hover:text-white uppercase transition-colors">
                      Pago
                    </button>
                  </form>
                  <form action="/admin/preorders/actions" method="POST" onsubmit="return confirm('¿Cancelar esta reserva?')">
                    <input type="hidden" name="_action" value="cancelReservation" />
                    <input type="hidden" name="id" value={preorderId} />
                    <input type="hidden" name="reservationId" value={reservation.id} />
                    <button type="submit" class="text-[10px] font-black text-zinc-600 hover:text-red-500 uppercase transition-colors">
                      Cancelar
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          ))
        )
      }
    </tbody>
  </table>
</div>
