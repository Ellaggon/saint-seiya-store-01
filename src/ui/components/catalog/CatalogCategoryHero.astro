---
/**
 * CATALOG CATEGORY HERO
 * Cinematic category selector with parallax background images and large cards.
 * Transitions smoothly to the marketplace on selection.
 */
interface Props {
  categories: any[];
  currentCategory?: string;
  getCategoryUrl: (slug?: string) => string;
}

const { categories, currentCategory, getCategoryUrl } = Astro.props;
---

<div class="bg-black py-24 border-b border-zinc-900 border-t border-zinc-900">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="flex flex-col gap-16">
      <!-- Section Header -->
      <div class="relative overflow-hidden group">
        <div class="flex flex-col gap-4 text-center md:text-left">
          <p class="text-amber-500 text-[10px] font-black uppercase tracking-[0.5em] animate-in fade-in slide-in-from-left duration-700">Consign Your Archive</p>
          <h2 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter leading-none animate-in fade-in slide-in-from-left duration-1000">Select a Sacred Saga</h2>
          <div class="w-16 h-1 bg-amber-500 mx-auto md:mx-0 mt-4 animate-in zoom-in duration-500"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- ALL ARCHIVE CARD -->
        <a
          href={getCategoryUrl()}
          data-filter-link
          data-category-card
          class={`relative group overflow-hidden bg-zinc-950 border aspect-[16/9] transition-all duration-700 flex flex-col items-center justify-center text-center gap-6 shadow-2xl ${
            !currentCategory 
              ? "border-amber-500 bg-amber-500/5 shadow-[0_0_50px_rgba(212,175,55,0.1)]" 
              : "border-zinc-900 hover:border-amber-500 hover:scale-[1.02]"
          }`}
        >
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent z-10"></div>
          
          <div class="relative z-20 flex flex-col items-center gap-4 p-8">
            <span class={`text-3xl font-black tracking-[0.3em] uppercase transition-all duration-700 group-hover:tracking-[0.4em] ${
              !currentCategory ? "text-amber-500" : "text-white group-hover:text-amber-500"
            }`}>
              COMPLETE ARCHIVE
            </span>
            <div class={`h-px bg-amber-500/30 transition-all duration-700 ${
              !currentCategory ? "w-24 bg-amber-500" : "w-12 group-hover:w-24 group-hover:bg-amber-500"
            }`}></div>
            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-[0.4em] transform translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
              UNIFY ALL CHAPTERS
            </p>
          </div>
        </a>

        {categories.map((cat) => (
          <a
            href={getCategoryUrl(cat.slug)}
            data-filter-link
            data-category-card
            class={`relative group overflow-hidden bg-zinc-950 border aspect-[16/9] transition-all duration-700 flex flex-col items-center justify-center text-center shadow-2xl ${
              currentCategory === cat.slug 
                ? "border-amber-500 shadow-[0_0_50px_rgba(212,175,55,0.1)]" 
                : "border-zinc-900 hover:border-amber-500 hover:scale-[1.02]"
            }`}
          >
            <!-- Parallax Background Container -->
            <div 
              class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-1000 ease-out group-hover:scale-110 parallax-bg"
              style={cat.imageUrl ? `background-image: url(${cat.imageUrl});` : `background: linear-gradient(to top, #09090b, #18181b);`}
              data-parallax-strength="15"
            ></div>

            <!-- Overlays -->
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 z-10 group-hover:opacity-90 transition-opacity"></div>
            <div class={`absolute inset-0 border-0 border-amber-500/0 z-10 transition-all duration-700 group-hover:border-[1px] group-hover:border-amber-500/20 active-glow ${currentCategory === cat.slug ? "opacity-100" : "opacity-0"}`}></div>
            
            <!-- Content -->
            <div class="relative z-20 flex flex-col items-center gap-4 p-8">
              <span class={`text-2xl md:text-3xl font-black tracking-[0.2em] uppercase transition-all duration-700 group-hover:tracking-[0.4em] text-center drop-shadow-2xl ${
                currentCategory === cat.slug ? "text-amber-500" : "text-white group-hover:text-amber-500"
              }`}>
                {cat.name}
              </span>
              
              <div class={`h-px transition-all duration-700 ${
                currentCategory === cat.slug ? "w-24 bg-amber-500" : "w-12 bg-zinc-700 group-hover:w-24 group-hover:bg-amber-500"
              }`}></div>
              
              <div class="flex items-center gap-3 overflow-hidden">
                <span class="text-zinc-500 text-[10px] font-black uppercase tracking-[0.3em] group-hover:text-amber-500/60 transition-colors">Chapter</span>
                <span class="w-1 h-1 rounded-full bg-zinc-800"></span>
                <span class="text-zinc-600 text-[10px] font-bold uppercase tracking-widest group-hover:text-white transition-colors">Decoded</span>
              </div>
            </div>

            <!-- Spotlight Scanning Effect -->
            <div class="absolute -inset-full bg-gradient-to-tr from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1500 ease-in-out pointer-events-none z-30"></div>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  /**
   * PARALLAX SYSTEM
   * Implements subtle background movement based on mouse position
   */
  const cards = document.querySelectorAll('[data-category-card]');
  
  cards.forEach(card => {
    const bg = card.querySelector('.parallax-bg') as HTMLElement;
    if (!bg) return;

    let rafId: number;
    const strength = parseInt(bg.dataset.parallaxStrength || '20');
    
    card.addEventListener('mousemove', (e: any) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        bg.style.transform = `scale(1.1) translate(${x * strength}px, ${y * strength}px)`;
      });
    });

    card.addEventListener('mouseleave', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        bg.style.transform = 'scale(1) translate(0, 0)';
      });
    });
  });

  /**
   * SMOOTH SCROLL SYSTEM
   * Jumps to marketplace after selection with tactical delay
   */
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const card = target.closest("[data-category-card]");
    
    if (card) {
      const marketplace = document.getElementById("catalog-marketplace");
      if (marketplace) {
        setTimeout(() => {
          marketplace.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });
        }, 120);
      }
    }
  });
</script>

<style>
  /* Cinematic Glow Pulsing */
  .active-glow {
    box-shadow: inset 0 0 30px rgba(212, 175, 55, 0.1);
    animation: glow-pulse 3s infinite ease-in-out;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }

  /* Force 16/9 aspect ratio fallback if needed */
  .aspect-\[16\/9\] {
    aspect-ratio: 16 / 9;
  }
</style>
