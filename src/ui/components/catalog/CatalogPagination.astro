---
interface Props {
  currentPage: number;
  totalPages: number;
  pageSize: number;
  getPageUrl: (page: number) => string;
}

const { currentPage, totalPages, getPageUrl } = Astro.props;

const hasPrevious = currentPage > 1;
const hasNext = currentPage < totalPages;
---

{
  totalPages > 1 && (
    <nav
      class="mt-10 border-t border-zinc-900 pt-6 flex items-center justify-between gap-4"
      aria-label="Catalog pagination"
    >
      <a
        href={hasPrevious ? getPageUrl(currentPage - 1) : "#"}
        data-filter-link
        data-page-link
        aria-disabled={hasPrevious ? "false" : "true"}
        class={`border px-4 py-2 text-[10px] font-black uppercase tracking-widest transition-colors ${
          hasPrevious
            ? "border-zinc-800 text-zinc-300 hover:border-amber-500 hover:text-amber-500"
            : "border-zinc-900 text-zinc-700 pointer-events-none"
        }`}
      >
        Prev
      </a>

      <div class="flex items-center gap-2 flex-wrap justify-center">
        {
          Array.from({ length: totalPages }, (_, idx) => idx + 1).map(
            (pageNumber) => (
              <a
                href={getPageUrl(pageNumber)}
                data-filter-link
                data-page-link
                aria-current={pageNumber === currentPage ? "page" : "false"}
                class={`min-w-9 text-center border px-3 py-2 text-[10px] font-black uppercase tracking-widest transition-colors ${
                  pageNumber === currentPage
                    ? "border-amber-500 text-amber-500 bg-amber-500/10"
                    : "border-zinc-800 text-zinc-300 hover:border-amber-500 hover:text-amber-500"
                }`}
              >
                {pageNumber}
              </a>
            ),
          )
        }
      </div>

      <a
        href={hasNext ? getPageUrl(currentPage + 1) : "#"}
        data-filter-link
        data-page-link
        aria-disabled={hasNext ? "false" : "true"}
        class={`border px-4 py-2 text-[10px] font-black uppercase tracking-widest transition-colors ${
          hasNext
            ? "border-zinc-800 text-zinc-300 hover:border-amber-500 hover:text-amber-500"
            : "border-zinc-900 text-zinc-700 pointer-events-none"
        }`}
      >
        Next
      </a>
    </nav>
  )
}
