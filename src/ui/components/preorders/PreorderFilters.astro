---
interface FilterOption {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  currentFilters: {
    collection?: string;
    character?: string;
    availability?: string;
    sort?: string;
  };
  collections: FilterOption[];
  characters: FilterOption[];
}

const { currentFilters, collections, characters } = Astro.props;

const availability = [
  { name: "AVAILABLE", value: "AVAILABLE" },
  { name: "SOLD OUT", value: "SOLD_OUT" },
];

const getFilterUrl = (key: string, value: string | null) => {
  const url = new URL(Astro.url.pathname, Astro.url.origin);
  const params = new URLSearchParams(Astro.url.search);

  if (value === null) {
    params.delete(key);
  } else {
    params.set(key, value);
  }
  params.delete("page");

  return `${url.pathname}?${params.toString()}`;
};

const hasActiveFilters = Boolean(
  currentFilters.collection ||
    currentFilters.character ||
    currentFilters.availability,
);
---

<aside class="w-full lg:w-[280px] flex-shrink-0">
  <input type="checkbox" id="preorder-filter-toggle" class="peer sr-only" />

  <label
    for="preorder-filter-toggle"
    class="lg:hidden flex items-center justify-between border border-zinc-900 bg-zinc-950 px-5 py-4 cursor-pointer hover:border-amber-500 transition-colors mb-8 group"
  >
    <span class="text-amber-500 font-black text-[11px] uppercase tracking-widest">
      TOGGLE FILTERS
    </span>
    <span class="text-amber-500 text-lg leading-none">+</span>
  </label>

  <div class="hidden peer-checked:block lg:block space-y-8">
    {
      hasActiveFilters && (
        <a
          href="/preorders"
          data-preorder-filter-link
          class="inline-block text-amber-500 text-[9px] font-black uppercase tracking-[0.2em] border border-amber-500/30 px-4 py-2 hover:bg-amber-500 hover:text-black transition-all mb-4"
        >
          CLEAR ALL FILTERS
        </a>
      )
    }

    <details open class="group/section">
      <summary class="flex items-center justify-between cursor-pointer list-none py-3 border-b border-zinc-900">
        <h3 class="text-amber-500 font-black text-[10px] uppercase tracking-[0.3em]">
          AVAILABILITY
        </h3>
        <span class="text-amber-500 text-xs transition-transform group-open/section:rotate-45">+</span>
      </summary>
      <ul class="flex flex-col gap-2 mt-4">
        {
          availability.map((item) => (
            <li>
              <a
                href={getFilterUrl("availability", item.value)}
                data-preorder-filter-link
                class={`group/item block border px-5 py-3 transition-colors bg-zinc-950 ${
                  currentFilters.availability === item.value
                    ? "border-amber-500"
                    : "border-zinc-900 hover:border-zinc-700"
                }`}
              >
                <span class={`text-[11px] font-black uppercase tracking-widest flex items-center justify-between ${
                  currentFilters.availability === item.value
                    ? "text-amber-500"
                    : "text-zinc-500 group-hover/item:text-zinc-300"
                }`}>
                  {item.name}
                  <span class="text-amber-500">
                    {currentFilters.availability === item.value ? "✓" : "+"}
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </details>

    {
      collections.length > 0 && (
        <details class="group/section">
          <summary class="flex items-center justify-between cursor-pointer list-none py-3 border-b border-zinc-900">
            <h3 class="text-amber-500 font-black text-[10px] uppercase tracking-[0.3em]">
              FILTER BY LINE
            </h3>
            <span class="text-amber-500 text-xs transition-transform group-open/section:rotate-45">+</span>
          </summary>
          <ul class="flex flex-col gap-2 mt-4">
            {collections.map((item) => (
              <li>
                <a
                  href={getFilterUrl("collection", item.slug)}
                  data-preorder-filter-link
                  class={`group/item block border px-5 py-3 transition-colors bg-zinc-950 ${
                    currentFilters.collection === item.slug
                      ? "border-amber-500"
                      : "border-zinc-900 hover:border-zinc-700"
                  }`}
                >
                  <span class={`text-[11px] font-black uppercase tracking-widest flex items-center justify-between ${
                    currentFilters.collection === item.slug
                      ? "text-amber-500"
                      : "text-zinc-500 group-hover/item:text-zinc-300"
                  }`}>
                    <span>{item.name} <span class="text-[9px] opacity-40">({item.count})</span></span>
                    <span class="text-amber-500">{currentFilters.collection === item.slug ? "✓" : "+"}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      )
    }

    {
      characters.length > 0 && (
        <details class="group/section">
          <summary class="flex items-center justify-between cursor-pointer list-none py-3 border-b border-zinc-900">
            <h3 class="text-amber-500 font-black text-[10px] uppercase tracking-[0.3em]">
              FILTER BY CHARACTER
            </h3>
            <span class="text-amber-500 text-xs transition-transform group-open/section:rotate-45">+</span>
          </summary>
          <ul class="flex flex-col gap-2 mt-4">
            {characters.map((item) => (
              <li>
                <a
                  href={getFilterUrl("character", item.slug)}
                  data-preorder-filter-link
                  class={`group/item block border px-5 py-3 transition-colors bg-zinc-950 ${
                    currentFilters.character === item.slug
                      ? "border-amber-500"
                      : "border-zinc-900 hover:border-zinc-700"
                  }`}
                >
                  <span class={`text-[11px] font-black uppercase tracking-widest flex items-center justify-between ${
                    currentFilters.character === item.slug
                      ? "text-amber-500"
                      : "text-zinc-500 group-hover/item:text-zinc-300"
                  }`}>
                    <span>{item.name} <span class="text-[9px] opacity-40">({item.count})</span></span>
                    <span class="text-amber-500">{currentFilters.character === item.slug ? "✓" : "+"}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      )
    }
  </div>
</aside>
