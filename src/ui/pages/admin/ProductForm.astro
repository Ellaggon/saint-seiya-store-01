---
import MainLayout from "@/ui/layouts/MainLayout.astro";

interface Props {
  product?: any;
  categories: any[];
  collections: any[];
  isEditing?: boolean;
}

const { product, categories, collections, isEditing = false } = Astro.props;

const statusOptions = [
  "DRAFT",
  "PUBLISHED",
  "PRE_ORDER",
  "OUT_OF_STOCK",
  "ARCHIVED",
];
---

<MainLayout
  title={isEditing ? `Editar - ${product.name}` : "Admin - Nueva Figura"}
>
  <div class="max-w-[800px] mx-auto px-6 py-12">
    <!-- Back Button -->
    <a
      href="/admin/products"
      class="inline-flex items-center text-zinc-500 hover:text-white transition-colors text-[10px] font-black uppercase tracking-widest mb-8"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="square"
        stroke-linejoin="round"
        class="mr-2"
        ><path d="m15 18-6-6 6-6"></path>
      </svg>
      Volver al Listado
    </a>

    <!-- Header -->
    <div class="space-y-2 mb-12">
      <p
        class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em]"
      >
        {isEditing ? "Edición de Archivo" : "Nueva Entrada"}
      </p>
      <h1 class="text-4xl font-black text-white uppercase tracking-tighter">
        {isEditing ? product.name : "Inscribir Figura"}
      </h1>
      <div class="w-12 h-1 bg-amber-500"></div>
    </div>

    <!-- Form Section -->
    <form
      action="/admin/products/actions"
      method="POST"
      onsubmit="this.querySelector('button[type=submit]').disabled = true;"
      class="space-y-8 bg-zinc-950 p-8 border border-zinc-900 shadow-2xl"
    >
      <input
        type="hidden"
        name="_action"
        value={isEditing ? "update" : "create"}
      />
      {isEditing && <input type="hidden" name="id" value={product.id} />}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Name -->
        <div class="space-y-2">
          <label
            for="name"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Nombre de la Figura</label
          >
          <input
            type="text"
            id="name"
            name="name"
            value={product?.name || ""}
            required
            placeholder="Ej: Seiya de Pegaso V3"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Slug -->
        <div class="space-y-2">
          <label
            for="slug"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >URL Personalizada {isEditing ? "" : "(Opcional)"}</label
          >
          <input
            type="text"
            id="slug"
            name="slug"
            value={product?.slug || ""}
            placeholder="seiya-pegaso-v3-ex"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Price -->
        <div class="space-y-2">
          <label
            for="price"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Precio (EUR)</label
          >
          <input
            type="number"
            id="price"
            name="price"
            value={product?.price?.toString() || ""}
            step="0.01"
            required
            placeholder="99.99"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <!-- Height -->
        <div class="space-y-2">
          <label
            for="height"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Altura (cm)</label
          >
          <input
            type="number"
            id="height"
            name="height"
            value={product?.height?.toString() || ""}
            step="0.1"
            required
            placeholder="18.0"
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
          />
        </div>

        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <label
              for="categoryId"
              class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
              >Saga de la Historia</label
            >
            <button
              type="button"
              data-create-popup="/admin/categories/new?popup=true"
              class="text-[8px] font-black text-zinc-500 hover:text-amber-500 uppercase tracking-widest transition-colors cursor-pointer"
              >+ Crear nueva saga</button
            >
          </div>
          <select
            id="categoryId"
            name="categoryId"
            required
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors appearance-none cursor-pointer"
          >
            <option value="" disabled={!isEditing} selected={!isEditing}
              >Seleccionar saga...</option
            >
            {
              categories.map((cat) => (
                <option
                  value={cat.id}
                  selected={cat.id === product?.categoryId}
                >
                  {cat.name}
                </option>
              ))
            }
          </select>
        </div>

        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <label
              for="collectionId"
              class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
              >Línea de Producto</label
            >
            <button
              type="button"
              data-create-popup="/admin/collections/new?popup=true"
              class="text-[8px] font-black text-zinc-500 hover:text-amber-500 uppercase tracking-widest transition-colors cursor-pointer"
              >+ Crear nueva línea</button
            >
          </div>
          <select
            id="collectionId"
            name="collectionId"
            required
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors appearance-none cursor-pointer"
          >
            <option value="" disabled={!isEditing} selected={!isEditing}
              >Seleccionar línea...</option
            >
            {
              collections.map((coll) => (
                <option
                  value={coll.id}
                  selected={coll.id === product?.collectionId}
                >
                  {coll.name}
                </option>
              ))
            }
          </select>
        </div>

        <!-- Status -->
        <div class="space-y-2">
          <label
            for="status"
            class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
            >Estado del Archivo</label
          >
          <select
            id="status"
            name="status"
            required
            class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors appearance-none cursor-pointer"
          >
            {
              statusOptions.map((opt) => (
                <option value={opt} selected={opt === product?.status}>
                  {opt}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <!-- Image Upload Component -->
      <div class="space-y-4">
        <label
          class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
          >Imagen de la Figura</label
        >

        <div class="flex flex-col gap-4">
          <!-- File Input -->
          <div class="relative group">
            <input
              type="file"
              id="image-upload"
              accept="image/jpeg,image/png,image/webp"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
            />
            <div
              class="w-full bg-black border border-zinc-800 px-4 py-8 text-center border-dashed group-hover:border-amber-500 transition-colors"
            >
              <span
                id="upload-status"
                class="text-zinc-500 text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"
                  stroke-linejoin="round"
                  ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                  ></path><polyline points="17 8 12 3 7 8"></polyline><line
                    x1="12"
                    x2="12"
                    y1="3"
                    y2="15"></line>
                </svg>
                Seleccionar Archivo (Max 5MB)
              </span>
            </div>
          </div>

          <!-- Hidden Input for the URL -->
          <input
            type="hidden"
            id="imageUrl"
            name="imageUrl"
            value={product?.imageUrl || ""}
            required
          />

          <!-- Preview Container -->
          <div
            id="image-preview-container"
            class={`space-y-2 ${product?.imageUrl ? "" : "hidden"}`}
          >
            <p
              class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest"
            >
              Previsualización del Archivo:
            </p>
            <div
              class="flex items-center gap-3 bg-zinc-900/50 p-3 border border-zinc-800"
            >
              <div
                class="w-12 h-12 bg-black border border-zinc-700 overflow-hidden flex-shrink-0"
              >
                <img
                  id="image-preview"
                  src={product?.imageUrl}
                  class="w-full h-full object-contain"
                />
              </div>
              <div class="flex flex-col min-w-0">
                <span
                  id="image-url-text"
                  class="text-[10px] text-zinc-400 truncate font-mono"
                >
                  {product?.imageUrl}
                </span>
                <span class="text-[8px] text-amber-500/50 font-black uppercase"
                  >Subido al Servidor R2</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="space-y-2">
        <label
          for="description"
          class="block text-[10px] font-black text-amber-500 uppercase tracking-widest"
          >Crónicas de la Armadura (Descripción)</label
        >
        <textarea
          id="description"
          name="description"
          rows="5"
          required
          placeholder="Describe la figura, materiales, accesorios y contexto histórico..."
          class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors resize-none"
          >{product?.description || ""}</textarea
        >
      </div>

      <!-- Submit Button -->
      <div class="pt-6">
        <button
          type="submit"
          class="w-full bg-white text-black text-[11px] font-black uppercase tracking-[0.2em] py-5 hover:bg-amber-500 transition-all duration-300"
        >
          {
            isEditing
              ? "Guardar Cambios en el Archivo"
              : "Consagrar Figura en el Santuario"
          }
        </button>
      </div>
    </form>
  </div>
</MainLayout>

<script>
  const fileInput = document.getElementById("image-upload") as HTMLInputElement;
  const statusText = document.getElementById("upload-status");
  const imageUrlInput = document.getElementById("imageUrl") as HTMLInputElement;
  const previewContainer = document.getElementById("image-preview-container");
  const previewImg = document.getElementById(
    "image-preview",
  ) as HTMLImageElement;
  const urlText = document.getElementById("image-url-text");

  fileInput?.addEventListener("change", async () => {
    const file = fileInput.files?.[0];
    if (!file) return;

    // Visual feedback
    const originalStatus = statusText?.innerHTML;
    if (statusText)
      statusText.textContent = "CONSIGNANDO AL SANTUARIO (SUBIENDO)...";
    fileInput.disabled = true;

    const formData = new FormData();
    formData.append("file", file);

    try {
      const response = await fetch("/api/upload-product-image", {
        method: "POST",
        body: formData,
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || "Error en la subida");
      }

      const data = await response.json();

      // Update hidden input
      if (imageUrlInput) {
        imageUrlInput.value = data.url;
      }

      // Update preview
      if (previewImg) previewImg.src = data.url;
      if (urlText) urlText.textContent = data.url;
      if (previewContainer) previewContainer.classList.remove("hidden");
      if (statusText)
        statusText.textContent = "¡ARMADURA REGISTRADA CON ÉXITO!";

      setTimeout(() => {
        if (statusText && originalStatus) statusText.innerHTML = originalStatus;
      }, 3000);
    } catch (error: any) {
      console.error("Upload error:", error);
      if (statusText) {
        statusText.textContent = "ERROR EN EL REGISTRO: " + error.message;
        statusText.classList.add("text-red-500");
      }
    } finally {
      fileInput.disabled = false;
    }
  });

  // Popup Management
  document.querySelectorAll("[data-create-popup]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const url = btn.getAttribute("data-create-popup");
      if (url) {
        window.open(
          url,
          "createPopup",
          "width=600,height=700,resizable=yes,scrollbars=yes"
        );
      }
    });
  });

  window.addEventListener("message", (event) => {
    if (event.data.type === "category-created") {
      const { id, name } = event.data.category;
      const select = document.getElementById("categoryId") as HTMLSelectElement;
      if (select) {
        const option = document.createElement("option");
        option.value = id;
        option.textContent = name;
        option.selected = true;
        select.appendChild(option);
      }
    }

    if (event.data.type === "collection-created") {
      const { id, name } = event.data.collection;
      const select = document.getElementById(
        "collectionId"
      ) as HTMLSelectElement;
      if (select) {
        const option = document.createElement("option");
        option.value = id;
        option.textContent = name;
        option.selected = true;
        select.appendChild(option);
      }
    }
  });
</script>
