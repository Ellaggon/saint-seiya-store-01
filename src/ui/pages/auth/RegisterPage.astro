---
import MainLayout from "../../layouts/MainLayout.astro";

interface Props {
  returnTo?: string;
}

const { returnTo = "/" } = Astro.props;
---

<MainLayout title="Registro de Caballero">
  <div class="min-h-[80vh] flex items-center justify-center px-6">
    <div
      class="w-full max-w-md space-y-8 bg-zinc-950 p-8 border border-zinc-900 shadow-2xl"
    >
      <div class="text-center space-y-2">
        <div class="w-12 h-px bg-amber-500 mx-auto mb-6"></div>
        <h1 class="text-3xl font-black text-white uppercase tracking-tighter">
          Nueva Reclutación
        </h1>
        <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest">
          Únete a las filas del Santuario
        </p>
      </div>

      <form id="register-form" class="mt-8 space-y-6">
        <div class="space-y-4">
          <div>
            <label
              for="name"
              class="block text-[10px] font-black text-amber-500 uppercase tracking-widest mb-2"
              >Nombre de Caballero</label
            >
            <input
              id="name"
              name="name"
              type="text"
              required
              class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
              placeholder="Saga de Géminis"
            />
          </div>
          <div>
            <label
              for="email"
              class="block text-[10px] font-black text-amber-500 uppercase tracking-widest mb-2"
              >Correo Electrónico</label
            >
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
              placeholder="caballero@santuario.com"
            />
          </div>
          <div>
            <label
              for="password"
              class="block text-[10px] font-black text-amber-500 uppercase tracking-widest mb-2"
              >Contraseña Sagrada</label
            >
            <input
              id="password"
              name="password"
              type="password"
              required
              class="w-full bg-black border border-zinc-800 px-4 py-3 text-white text-sm focus:border-amber-500 focus:outline-none transition-colors"
              placeholder="••••••••"
            />
          </div>
        </div>

        <div
          id="error-message"
          class="hidden text-red-500 text-[11px] font-bold uppercase tracking-wider bg-red-500/10 p-3 border border-red-500/20"
        >
          <!-- Error message -->
        </div>

        <div
          id="success-message"
          class="hidden text-amber-500 text-[11px] font-bold uppercase tracking-wider bg-amber-500/10 p-4 border border-amber-500/20"
        >
          <p>
            Registro exitoso. Se ha enviado un correo de confirmación (si está
            habilitado) o ya puedes iniciar sesión.
          </p>
        </div>

        <div>
          <button
            type="submit"
            id="submit-button"
            class="group w-full flex justify-center items-center py-4 px-4 border border-zinc-800 text-xs font-black text-white uppercase tracking-[0.2em] hover:bg-white hover:text-black transition-all duration-300 focus:outline-none"
          >
            <span id="button-text">JURAR LEALTAD</span>
            <div
              id="loading-spinner"
              class="hidden ml-2 w-4 h-4 border-2 border-zinc-500 border-t-white rounded-full animate-spin"
            >
            </div>
          </button>
        </div>
      </form>

      <div class="text-center pt-4">
        <p
          class="text-zinc-600 text-[10px] uppercase tracking-widest font-bold"
        >
          ¿Ya eres un caballero?
          <a
            href="/login"
            class="text-white hover:text-amber-500 transition-colors ml-1 border-b border-zinc-800 hover:border-amber-500 pb-0.5"
            >Inicia sesión</a
          >
        </p>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../../../lib/supabaseClient";

  const registerForm = document.getElementById(
    "register-form",
  ) as HTMLFormElement;
  const submitButton = document.getElementById(
    "submit-button",
  ) as HTMLButtonElement;
  const buttonText = document.getElementById("button-text");
  const loadingSpinner = document.getElementById("loading-spinner");
  const errorDisplay = document.getElementById("error-message");
  const successDisplay = document.getElementById("success-message");

  registerForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(registerForm);
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const name = formData.get("name") as string;

    // Reset states
    if (errorDisplay) {
      errorDisplay.classList.add("hidden");
      errorDisplay.textContent = "";
    }

    if (submitButton) submitButton.disabled = true;
    buttonText?.classList.add("opacity-50");
    loadingSpinner?.classList.remove("hidden");

    try {
      const { data, error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          data: {
            full_name: name,
          },
        },
      });

      if (error) throw error;

      if (data.user && data.session) {
        window.location.href = "/";
      } else {
        successDisplay?.classList.remove("hidden");
        registerForm.classList.add("hidden");
      }
    } catch (error: any) {
      console.error("Registration error:", error);
      if (errorDisplay) {
        errorDisplay.classList.remove("hidden");
        errorDisplay.textContent = error.message || "Error en el registro";
      }

      if (submitButton) submitButton.disabled = false;
      buttonText?.classList.remove("opacity-50");
      loadingSpinner?.classList.add("hidden");
    }
  });
</script>
