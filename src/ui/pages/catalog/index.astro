---
import MainLayout from "../../layouts/MainLayout.astro";
import GlobalHeroWrapper from "../../components/layout/GlobalHeroWrapper.astro";
import Section from "../../components/layout/Section.astro";

/**
 * CATALOG PAGE (THE SANCTUARY)
 * Implementation using Master Layout System.
 */
---

<MainLayout title="CATÁLOGO">
  <GlobalHeroWrapper 
    title="Santuario" 
    subtitle="ARCHIVO SAGRADO DE FIGURAS Y GALERÍA PREMIUM."
  />

  <Section variant="black" withBorder={true}>
    <div class="flex flex-col lg:flex-row gap-16">
      <!-- Filter Sidebar -->
      <aside class="w-full lg:w-72 space-y-12">
        <div class="space-y-6">
          <h2 class="text-amber-500 font-black uppercase tracking-[0.3em] text-[10px]">FILTRAR POR LÍNEA</h2>
          <ul class="flex flex-col gap-2">
            {['MYTH CLOTH EX', 'SOUL OF GOLD', 'VINTAGE 80S'].map((line) => (
              <li class="group border border-zinc-900 px-6 py-4 cursor-pointer hover:border-amber-500 transition-colors">
                <span class="text-zinc-500 group-hover:text-white text-[11px] font-black uppercase tracking-widest transition-colors">{line}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-6">
          <h2 class="text-amber-500 font-black uppercase tracking-[0.3em] text-[10px]">FILTRAR POR PERSONAJE</h2>
          <ul class="flex flex-col gap-2">
            {['PEGASUS SEIYA', 'GEMINI SAGA', 'VIRGO SHAKA'].map((char) => (
              <li class="group border border-zinc-900 px-6 py-4 cursor-pointer hover:border-amber-500 transition-colors">
                <span class="text-zinc-500 group-hover:text-white text-[11px] font-black uppercase tracking-widest transition-colors">{char}</span>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Product Grid -->
      <div class="flex-1">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="group relative aspect-square bg-zinc-950 border border-zinc-900 cursor-pointer transition-all duration-300 transform hover:scale-[1.02] hover:border-amber-500 hover:z-10">
              <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 to-transparent"></div>
              
              <!-- Placeholder Figure Image -->
              <div class="absolute inset-0 bg-zinc-900 animate-pulse flex items-center justify-center opacity-40">
                 <span class="text-zinc-800 font-black text-[10px] uppercase tracking-[0.5em]">SANCTUARY ARCHIVE</span>
              </div>

              <div class="absolute bottom-0 left-0 w-full p-8 space-y-2 translate-y-2 group-hover:translate-y-0 transition-transform">
                <span class="text-amber-500 font-black uppercase tracking-[0.3em] text-[8px]">PRE-ORDER</span>
                <h3 class="text-white text-lg font-black uppercase tracking-tight leading-none">Placeholder Figure</h3>
                <div class="flex items-center justify-between pt-4 opacity-0 group-hover:opacity-100 transition-opacity">
                   <span class="text-white font-black text-xl">$0.00</span>
                   <span class="text-amber-500 text-[9px] font-black uppercase tracking-widest border border-amber-500/30 px-3 py-1">DETALLES</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>
</MainLayout>
