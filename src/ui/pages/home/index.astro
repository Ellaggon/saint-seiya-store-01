---
import MainLayout from "../../layouts/MainLayout.astro";
import GlobalHeroWrapper from "../../components/layout/GlobalHeroWrapper.astro";
import Section from "../../components/layout/Section.astro";

/**
 * HOME PAGE
 * Demonstrating the Master Layout System.
 */
---

<MainLayout title="INICIO">
  <GlobalHeroWrapper
    title="Soul of Gold"
    subtitle="LA ARMADURA DIVINA DEFINITIVA. DISPONIBLE AHORA EN EL SANTUARIO."
    fullHeight={true}
  />

  <Section variant="dark" withBorder={true}>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <h2
          class="text-white text-5xl font-black uppercase tracking-tighter leading-none"
        >
          PRECISIÓN <br /> AL ESTILO <br />
          <span class="text-amber-500">TAMASHII</span>
        </h2>
        <p
          class="text-zinc-500 text-sm font-bold uppercase tracking-widest leading-relaxed"
        >
          Cada figura es una obra maestra de ingeniería. En THE SANCTUARY,
          seleccionamos únicamente las líneas más exclusivas para los
          coleccionistas más exigentes del cosmos.
        </p>
        <div class="pt-4">
          <a
            href="/catalogo"
            class="text-white text-xs font-black uppercase tracking-[0.3em] border-b border-amber-500 pb-2 hover:text-amber-500 hover:border-white transition-all"
          >
            VER TODAS LAS LÍNEAS
          </a>
        </div>
      </div>
      <div
        class="aspect-square bg-zinc-900 border border-zinc-800 flex items-center justify-center p-12"
      >
        <!-- Placeholder for high-end figure image -->
        <div
          class="w-full h-full border border-zinc-800 animate-pulse bg-zinc-950 flex items-center justify-center"
        >
          <span
            class="text-zinc-800 font-black text-xs uppercase tracking-[0.5em] -rotate-90"
            >MYTH CLOTH EX</span
          >
        </div>
      </div>
    </div>
  </Section>

  <Section variant="black" withBorder={true}>
    <div class="text-center mb-16">
      <h3
        class="text-amber-500 text-[10px] font-black uppercase tracking-[0.4em] mb-4"
      >
        CATEGORÍAS SACRAS
      </h3>
      <h2 class="text-white text-4xl font-black uppercase tracking-tighter">
        COLECCIONES DESTACADAS
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        ["MYTH CLOTH EX", "SOUL OF GOLD", "VINTAGE 80S"].map((cat) => (
          <div class="group relative aspect-[3/4] bg-zinc-950 border border-zinc-900 overflow-hidden cursor-pointer hover:border-amber-500 transition-all duration-300">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/80 z-10 transition-opacity group-hover:opacity-60" />
            <div class="absolute inset-0 z-0 bg-zinc-900 animate-pulse" />

            <div class="absolute inset-0 flex flex-col items-center justify-end p-8 z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <h4 class="text-white text-xl font-black uppercase tracking-tight mb-2">
                {cat}
              </h4>
              <span class="text-amber-500 text-[10px] font-black uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                EXPLORAR →
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </Section>
</MainLayout>
