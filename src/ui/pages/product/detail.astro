---
import MainLayout from "../../layouts/MainLayout.astro";
import type { PreorderDetailDTO } from "@/application/dto/preorder.dto";
import PreorderAvailabilityMeter from "../../components/preorders/PreorderAvailabilityMeter.astro";
import PreorderBadge from "../../components/preorders/PreorderBadge.astro";
import PreorderCTA from "../../components/preorders/PreorderCTA.astro";
import PreorderEta from "../../components/preorders/PreorderEta.astro";
import PreorderPriceSummary from "../../components/preorders/PreorderPriceSummary.astro";

interface Props {
  product: {
    id: string;
    name: string;
    description: string;
    price: number;
    categoryId: string;
    collectionId: string;
    height: number;
    material: string;
    imageUrl: string;
    stock: number;
    status: string;
    line?: string;
    character?: string;
    category?: string;
    characters?: string[];
  } | null;
  preorder?: PreorderDetailDTO | null;
}

const { product, preorder = null } = Astro.props;
const preorderIsSoldOut = preorder
  ? preorder.availability.availableUnits <= 0 || preorder.availability.isSoldOut
  : false;
const preorderIsOpen = preorder ? preorder.campaign.isOpen : false;

const statusLabelMap: Record<string, string> = {
  DRAFT: "DRAFT",
  PUBLISHED: "PUBLISHED",
  PRE_ORDER: "PRE-ORDER",
  OUT_OF_STOCK: "OUT OF STOCK",
  ARCHIVED: "ARCHIVED",
};
---

<MainLayout title={product ? `${product.name} | PRODUCT DETAIL` : "PRODUCT | DETAIL"}>
  <main class="min-h-screen bg-black">
    {
      product ? (
        <div class="max-w-[1280px] mx-auto px-4 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div class="w-full aspect-square border border-zinc-900 bg-zinc-950 overflow-hidden">
            <img
              src={product.imageUrl}
              alt={product.name}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <div class="flex flex-col gap-10">
            <div class="border-b border-zinc-900 pb-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-[10px] font-black uppercase tracking-widest px-2 py-1">
                  {statusLabelMap[product.status] ?? product.status}
                </span>
              </div>
              <h1 class="text-3xl md:text-5xl font-black uppercase text-white leading-tight">
                {product.name}
              </h1>
              <p class="text-amber-500 font-black mt-4 text-sm uppercase tracking-widest">
                ${product.price.toFixed(2)}
              </p>
            </div>

            <div class="space-y-4 border border-zinc-900 bg-zinc-950 px-5 py-5">
              <p class="text-zinc-300 text-xs uppercase tracking-widest font-bold">
                {product.description}
              </p>
              <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">
                Category: <span class="text-white">{product.category ?? "N/A"}</span>
              </p>
              <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">
                Collection: <span class="text-white">{product.line ?? "N/A"}</span>
              </p>
              <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">
                Characters:
                <span class="text-white">
                  {(product.characters && product.characters.length > 0
                    ? product.characters.join(", ")
                    : product.character) || "N/A"}
                </span>
              </p>
              <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">
                Height: <span class="text-white">{product.height} CM</span>
              </p>
              <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">
                Material: <span class="text-white">{product.material || "N/A"}</span>
              </p>
            </div>

            {
              preorder && (
                <section class="border border-zinc-900 bg-zinc-950 px-5 py-5 space-y-5">
                  <div class="flex items-center justify-between gap-4 border-b border-zinc-900 pb-4">
                    <div class="flex flex-col gap-2">
                      <span class="text-zinc-500 text-[9px] font-black uppercase tracking-[0.3em]">
                        Preorder Campaign
                      </span>
                      <h2 class="text-white text-sm font-black uppercase tracking-widest">
                        Reserved Allocation
                      </h2>
                    </div>
                    <PreorderBadge
                      isOpen={preorderIsOpen}
                      isSoldOut={preorderIsSoldOut}
                    />
                  </div>

                  <PreorderEta etaLabel={preorder.eta.etaLabel || preorder.eta.etaStart} />

                  <PreorderAvailabilityMeter
                    availableUnits={preorder.availability.availableUnits}
                    totalUnits={preorder.availability.totalSlots}
                  />

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="border border-zinc-900 bg-black px-4 py-4">
                      <PreorderPriceSummary
                        depositAmount={preorder.pricing.depositRequired}
                      />
                    </div>
                    <div class="border border-zinc-900 bg-black px-4 py-4">
                      <div class="flex items-center justify-between gap-3">
                        <span class="text-zinc-500 text-[9px] font-black uppercase tracking-[0.2em]">
                          Full Price
                        </span>
                        <span class="text-amber-500 text-xs font-black uppercase tracking-widest">
                          ${preorder.pricing.totalAmount.toFixed(2)}
                        </span>
                      </div>
                    </div>
                  </div>

                  {
                    preorder.terms && (
                      <p class="text-zinc-500 text-[10px] uppercase tracking-widest leading-relaxed">
                        {preorder.terms}
                      </p>
                    )
                  }

                  <PreorderCTA
                    isOpen={preorderIsOpen}
                    isSoldOut={preorderIsSoldOut}
                  />

                  <p class="text-zinc-600 text-[9px] uppercase tracking-[0.2em]">
                    Login required to reserve. Checkout integration will attach to this
                    campaign flow in a later phase.
                  </p>
                </section>
              )
            }
          </div>
        </div>
      ) : (
        <div class="max-w-[1280px] mx-auto px-4 py-20">
          <div class="border border-zinc-900 bg-zinc-950 px-8 py-12">
            <h1 class="text-white text-xl font-black uppercase tracking-widest">
              Product not found
            </h1>
            <p class="text-zinc-500 text-xs uppercase tracking-widest mt-4">
              The requested product does not exist or is unavailable.
            </p>
          </div>
        </div>
      )
    }
  </main>
</MainLayout>
